{
  "name": "tiktok-ai",
  "private": true,
  "workspaces": [
    "apps/server",
    "apps/web"
  ],
  "scripts": {
    "dev": "concurrently \"npm:dev --workspace apps/server\" \"npm:dev --workspace apps/web\"",
    "build": "npm run build --workspace apps/server && npm run build --workspace apps/web",
    "start": "npm run start --workspace apps/server",
    "db:migrate": "npm run db:migrate --workspace apps/server",
    "db:seed": "npm run db:seed --workspace apps/server"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
