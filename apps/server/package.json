{
  "name": "tiktok-ai-server",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "db:migrate": "prisma migrate dev --schema src/db/prisma/schema.prisma",
    "db:seed": "tsx src/db/seed.ts",
    "db:generate": "prisma generate --schema src/db/prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "ffmpeg-static": "^5.2.0",
    "ffprobe-static": "^3.1.0",
    "morgan": "^1.10.0",
    "openai": "^4.83.0",
    "uuid": "^11.1.0",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.30",
    "@types/morgan": "^1.9.9",
    "prisma": "^6.6.0",
    "tsx": "^4.19.2",
    "typescript": "^5.8.2"
  }
}
