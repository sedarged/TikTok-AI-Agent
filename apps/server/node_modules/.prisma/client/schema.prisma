generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Project {
  id                  String   @id @default(uuid())
  title               String
  nichePackId         String
  language            String
  targetLengthSec     Int
  tempo               String
  voicePreset         String
  visualStylePreset   String?
  status              String   @default("DRAFT_PLAN") // DRAFT_PLAN | PLAN_READY | APPROVED | RENDERING | DONE | FAILED
  latestPlanVersionId String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  planVersions PlanVersion[]
  runs         Run[]
  scenes       Scene[]
}

model PlanVersion {
  id              String   @id @default(uuid())
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id])
  hookOptionsJson String // string[]
  hookSelected    String?
  outline         String?
  scriptFull      String?
  estimatesJson   String? // { wpm, estimatedLengthSec, targetLengthSec }
  validationJson  String? // { errors, warnings, suggestions }
  createdAt       DateTime @default(now())

  scenes Scene[]
  runs   Run[]
}

model Scene {
  id                String      @id @default(uuid())
  projectId         String
  project           Project     @relation(fields: [projectId], references: [id])
  planVersionId     String
  planVersion       PlanVersion @relation(fields: [planVersionId], references: [id])
  idx               Int
  narrationText     String
  onScreenText      String
  visualPrompt      String
  negativePrompt    String
  effectPreset      String
  durationTargetSec Float
  startTimeSec      Float?
  endTimeSec        Float?
  isLocked          Boolean     @default(false)
  updatedAt         DateTime    @updatedAt
}

model Run {
  id              String      @id @default(uuid())
  projectId       String
  project         Project     @relation(fields: [projectId], references: [id])
  planVersionId   String
  planVersion     PlanVersion @relation(fields: [planVersionId], references: [id])
  status          String // queued|running|done|failed|canceled
  progress        Int         @default(0)
  currentStep     String?
  logsJson        String? // append-only list with timestamps
  artifactsJson   String? // { imagesDir, audioDir, captionsPath, mp4Path, thumbPath, exportJsonPath }
  resumeStateJson String? // { lastCompletedStep, completedSceneIdxs[] }
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model Cache {
  id          String   @id @default(uuid())
  kind        String // llm/images/tts/asr
  hashKey     String   @unique
  resultJson  String?
  payloadPath String?
  createdAt   DateTime @default(now())
}
