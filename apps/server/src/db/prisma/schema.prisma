generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum ProjectStatus {
  DRAFT_PLAN
  PLAN_READY
  APPROVED
  RENDERING
  DONE
  FAILED
}

enum RunStatus {
  queued
  running
  done
  failed
  canceled
}

enum EffectPreset {
  slow_zoom_in
  slow_zoom_out
  pan_left
  pan_right
  tilt_up
  tilt_down
  flash_cut
  fade
  glitch
}

model Project {
  id                 String        @id @default(cuid())
  title              String
  nichePackId        String
  language           String
  targetLengthSec    Int
  tempo              String
  voicePreset        String
  visualStylePreset  String?
  status             ProjectStatus @default(DRAFT_PLAN)
  latestPlanVersionId String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  plans  PlanVersion[]
  scenes Scene[]
  runs   Run[]
}

model PlanVersion {
  id              String   @id @default(cuid())
  projectId       String
  createdAt       DateTime @default(now())
  hookOptionsJson Json
  hookSelected    String
  outline         String
  scriptFull      String
  estimatesJson   Json
  validationJson  Json

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  scenes  Scene[]
  runs    Run[]
}

model Scene {
  id                String       @id @default(cuid())
  projectId         String
  planVersionId     String
  idx               Int
  narrationText     String
  onScreenText      String
  visualPrompt      String
  negativePrompt    String
  effectPreset      EffectPreset
  durationTargetSec Float
  startTimeSec      Float
  endTimeSec        Float
  isLocked          Boolean      @default(false)
  updatedAt         DateTime     @updatedAt

  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  planVersion PlanVersion @relation(fields: [planVersionId], references: [id], onDelete: Cascade)

  @@index([projectId, planVersionId])
}

model Run {
  id             String    @id @default(cuid())
  projectId      String
  planVersionId  String
  status         RunStatus @default(queued)
  progress       Int       @default(0)
  currentStep    String?
  logsJson       Json
  artifactsJson  Json
  resumeStateJson Json
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  planVersion PlanVersion @relation(fields: [planVersionId], references: [id], onDelete: Cascade)

  @@index([projectId, planVersionId])
}

model Cache {
  id         String   @id @default(cuid())
  kind       String
  hashKey    String   @unique
  resultJson Json
  payloadPath String?
  createdAt  DateTime @default(now())
}
