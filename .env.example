# TikTok AI Agent - Environment Variables
# Copy this file to .env and configure as needed.

# ------------------------------------------------------------------------------
# Server Configuration
# ------------------------------------------------------------------------------
PORT=3001
NODE_ENV=development
# NODE_ENV=production  # Use in production

# Database (SQLite file path for Prisma)
# Relative paths are relative to apps/server
DATABASE_URL=file:./dev.db

# ------------------------------------------------------------------------------
# AI Providers (required for production, optional for dry-run mode)
# ------------------------------------------------------------------------------
# OpenAI API Key - Required for plan generation, image generation, TTS, and ASR
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ElevenLabs API Key - Optional, for premium voice synthesis
# Get yours at: https://elevenlabs.io/
ELEVENLABS_API_KEY=

# ------------------------------------------------------------------------------
# Application Paths (defaults are usually fine)
# ------------------------------------------------------------------------------
# Directory for rendered video artifacts and intermediate files
# ARTIFACTS_DIR=./artifacts

# Directory containing background music tracks
# MUSIC_LIBRARY_DIR=./assets/music

# ------------------------------------------------------------------------------
# Application Version (optional)
# ------------------------------------------------------------------------------
# APP_VERSION=1.0.0

# ------------------------------------------------------------------------------
# Testing & Development Modes
# ------------------------------------------------------------------------------
# APP_TEST_MODE=1          # Enable test mode (disables API calls, uses mocks)
# APP_RENDER_DRY_RUN=1     # Enable dry-run mode (skips actual rendering)
# APP_DRY_RUN_FAIL_STEP=   # Force a specific step to fail in dry-run (e.g., "images_generate")
# APP_DRY_RUN_STEP_DELAY_MS=0  # Add delay between dry-run steps (ms)
